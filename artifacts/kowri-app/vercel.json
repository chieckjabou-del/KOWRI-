{
  "framework": "vite",
  "buildCommand": "pnpm --filter @workspace/kowri-app run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "status": 404
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "methods": ["GET", "HEAD"],
      "dest": "/index.html"
    }
  ]
}
