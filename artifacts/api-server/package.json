{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx ./src/index.ts",
    "build:frontends": "pnpm --filter @workspace/kowri-app run build && pnpm --filter @workspace/kowri-dashboard run build",
    "build:backend": "pnpm --filter @workspace/db run build && pnpm --filter @workspace/api-zod run build && tsc -p tsconfig.json --noEmit false --pretty false && tsx ./build.ts",
    "build": "pnpm run build:backend",
    "start": "NODE_ENV=production node dist/index.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@workspace/db": "workspace:*",
    "@workspace/api-zod": "workspace:*",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "cookie-parser": "^1.4.7",
    "cors": "^2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/express": "^5.0.6",
    "@types/cors": "^2.8.19",
    "@types/cookie-parser": "^1.4.10",
    "esbuild": "^0.27.3",
    "tsx": "catalog:"
  }
}
